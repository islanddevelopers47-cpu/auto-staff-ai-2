{
  "name": "claw-staffer-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Claw Staffer — scheduled unpaid user cleanup",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
